# AWS Configuration
AWS_ACCOUNT_ID=your_12_digit_account_id
DEFAULT_AWS_REGION=us-east-1

# Project Configuration
PROJECT_NAME=twin

# OpenAI
# Required: add OPENAI_API_KEY as a GitHub Actions secret (Settings → Environments → dev/test/prod → Secrets)
OPENAI_API_KEY=sk-...
# Optional: override the model (default: gpt-4o-mini). Set LLM_MODEL_ID as a GitHub Actions secret to change it.
LLM_MODEL_ID=gpt-4o-mini

# Security — set to true only in trusted/local environments.
# When false the Oracle's execute_python tool returns a disabled response
# instead of running arbitrary code on the server.
ALLOW_CODE_EXECUTION=false

# Frontend — URL of the FastAPI backend (no trailing slash).
# In production this is set automatically by the deploy.sh script
# using the Terraform api_gateway_url output.
# For local development use:
NEXT_PUBLIC_API_URL=http://localhost:8000